#!/usr/bin/env bash
set -euo pipefail

# Colors
red='\033[0;31m'
reset='\033[0m'

usage() {
  echo "Usage: k8s-rds-psql <name> --context <cluster> [--port <local-port>] [--namespace <ns>] [--secret-name <secret>] [--username <user>] [--from-secret]"
  echo ""
  echo "  <name>          Database name, username, and secret name"
  echo "  --context       Kubernetes context (required)"
  echo "  --port          Local port (must match k8s-rds-tunnel, default: 35432)"
  echo "  --namespace     Kubernetes namespace (default: same as name)"
  echo "  --secret-name   Kubernetes secret name (default: <name>-secrets)"
  echo "  --username        Database username (default: derived from <name>)"
  echo "  --from-secret     Read DB_NAME and DB_USERNAME from the secret instead of deriving from <name>"
  echo "  --print-local-url Print the local port-forwarded connection URL to stdout and exit (no psql)"
}

# URL-encode per RFC 3986 unreserved set; everything else percent-encoded.
urlencode() {
  local s="$1" out="" i c
  for (( i = 0; i < ${#s}; i++ )); do
    c="${s:i:1}"
    case "$c" in
      [a-zA-Z0-9.~_-]) out+="$c" ;;
      *) printf -v c '%%%02X' "'$c"; out+="$c" ;;
    esac
  done
  printf '%s' "$out"
}

# Parse arguments
context=""
local_port=""
namespace=""
secret_name=""
username=""
from_secret=""
print_local_url=""
name=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -c|--context)
      context="$2"
      shift 2
      ;;
    -p|--port)
      local_port="$2"
      if ! [[ "$local_port" =~ ^[0-9]+$ ]] || (( local_port < 1 || local_port > 65535 )); then
        echo -e "${red}Invalid port: $local_port${reset}" >&2
        exit 1
      fi
      shift 2
      ;;
    -n|--namespace)
      namespace="$2"
      shift 2
      ;;
    -s|--secret-name)
      secret_name="$2"
      shift 2
      ;;
    -u|--username)
      username="$2"
      shift 2
      ;;
    --from-secret)
      from_secret="1"
      shift
      ;;
    --print-local-url)
      print_local_url="1"
      shift
      ;;
    -*)
      echo -e "${red}Unknown option: $1${reset}" >&2
      exit 1
      ;;
    *)
      name="$1"
      shift
      ;;
  esac
done

if [[ -z "$name" ]]; then
  usage
  exit 1
fi

if [[ -z "$context" ]]; then
  echo -e "${red}--context is required${reset}" >&2
  echo "Usage: k8s-rds-psql <name> --context <cluster>"
  exit 1
fi

local_port="${local_port:-35432}"
namespace="${namespace:-$name}"
db_name="${name//-/_}"

get_secret_key() {
  kubectl --context "$context" -n "$namespace" get secret "$secret_name" -o jsonpath="{.data.$1}" 2>&1
}

# Get credentials from k8s secret
secret_name="${secret_name:-${name}-secrets}"
echo "Looking up credentials from secret '$secret_name' in namespace '$namespace'..." >&2

if ! password=$(get_secret_key DB_PASSWORD); then
  echo -e "${red}Failed to get secret: $password${reset}" >&2
  exit 1
fi
password=$(echo "$password" | base64 --decode)

if [[ -n "$from_secret" ]]; then
  if secret_db_name=$(get_secret_key DB_NAME) && [[ -n "$secret_db_name" ]]; then
    db_name=$(echo "$secret_db_name" | base64 --decode)
  fi
  if [[ -z "$username" ]] && secret_username=$(get_secret_key DB_USERNAME) && [[ -n "$secret_username" ]]; then
    username=$(echo "$secret_username" | base64 --decode)
  fi
fi

# --username overrides; otherwise default to the derived db_name
username="${username:-$db_name}"

if [[ -n "$print_local_url" ]]; then
  printf 'postgres://%s:%s@localhost:%s/%s\n' \
    "$(urlencode "$username")" "$(urlencode "$password")" "$local_port" "$(urlencode "$db_name")"
  exit 0
fi

echo "Connecting to database '$db_name' as user '$username' on localhost:$local_port..." >&2
PGPASSWORD="$password" psql -h localhost -p "$local_port" -U "$username" -d "$db_name"
