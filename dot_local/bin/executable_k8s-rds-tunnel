#!/usr/bin/env bash
set -euo pipefail

# Colors
red='\033[0;31m'
reset='\033[0m'

usage() {
  echo "Usage: k8s-rds-tunnel <cluster-name> [--port <local-port>]"
  echo ""
  echo "Available clusters:"
  while IFS= read -r line; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line// /}" ]] && continue
    read -r name _ <<< "$line"
    echo "  $name"
  done < "$K8S_RDS_CONFIG"
}

# Parse arguments
local_port_override=""
cluster=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--port)
      local_port_override="$2"
      if ! [[ "$local_port_override" =~ ^[0-9]+$ ]] || (( local_port_override < 1 || local_port_override > 65535 )); then
        echo -e "${red}Invalid port: $local_port_override${reset}" >&2
        exit 1
      fi
      shift 2
      ;;
    -*)
      echo -e "${red}Unknown option: $1${reset}" >&2
      exit 1
      ;;
    *)
      cluster="$1"
      shift
      ;;
  esac
done

# Validate K8S_RDS_CONFIG
if [[ -z "${K8S_RDS_CONFIG:-}" ]]; then
  echo -e "${red}K8S_RDS_CONFIG is not set${reset}" >&2
  exit 1
fi

if [[ ! -f "$K8S_RDS_CONFIG" ]]; then
  echo -e "${red}Config file not found: $K8S_RDS_CONFIG${reset}" >&2
  exit 1
fi

if [[ -z "$cluster" ]]; then
  usage
  exit 1
fi

# Look up cluster in config
rds_host=""
region=""
remote_port=""
local_port=""
while IFS= read -r line; do
  [[ "$line" =~ ^[[:space:]]*# ]] && continue
  [[ -z "${line// /}" ]] && continue
  read -r name host rgn rport lport _ <<< "$line"
  if [[ "$name" == "$cluster" ]]; then
    rds_host="$host"
    region="$rgn"
    if [[ -z "$rport" ]]; then
      echo -e "${red}No remote port specified for cluster $cluster in config${reset}" >&2
      exit 1
    fi
    remote_port="$rport"
    if [[ -z "$lport" ]]; then
      echo -e "${red}No local port specified for cluster $cluster in config${reset}" >&2
      exit 1
    fi
    local_port="${local_port_override:-$lport}"
    break
  fi
done < "$K8S_RDS_CONFIG"

if [[ -z "$rds_host" ]]; then
  echo -e "${red}Unknown cluster: $cluster${reset}" >&2
  echo ""
  usage
  exit 1
fi

# Get a node instance ID from the cluster
echo "Getting node from cluster $cluster..."
if ! instance_id=$(kubectl --context "$cluster" get nodes -o jsonpath='{.items[0].spec.providerID}' 2>&1); then
  echo -e "${red}Failed to get node from cluster: $instance_id${reset}" >&2
  exit 1
fi

# Extract instance ID from provider ID (format: aws:///az/i-xxx)
instance_id="${instance_id##*/}"

if [[ -z "$instance_id" ]]; then
  echo -e "${red}No nodes found in cluster $cluster${reset}" >&2
  exit 1
fi

# Check if local port is already in use
if lsof -i :"$local_port" -sTCP:LISTEN >/dev/null 2>&1; then
  echo -e "${red}Port $local_port is already in use${reset}" >&2
  echo "Use --port to specify a different local port"
  exit 1
fi

echo "Using node: $instance_id"
echo "Forwarding localhost:$local_port -> $rds_host:$remote_port via $instance_id"
echo ""

aws ssm start-session \
  --region "$region" \
  --target "$instance_id" \
  --document-name AWS-StartPortForwardingSessionToRemoteHost \
  --parameters "host=$rds_host,portNumber=$remote_port,localPortNumber=$local_port"
